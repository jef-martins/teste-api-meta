# Configurações do banco de dados PostgreSQL
DB_HOST=localhost
DB_PORT=5433
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=postgres
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/postgres?schema=public"

# Ambiente: development → usa WPPConnect | production → usa Meta API
NODE_ENV=development

# Porta do servidor Express 
PORT=3000

# URL base para requisições externas (httpService)
API_BASE_URL=http://localhost:3000

#Configurações BOT
#BOT_NUMERO_ADMIN=5514998185825
BOT_NUMERO_ADMIN=5514998089672

# Modo de teste: se 'true', o bot responde APENAS ao número BOT_NUMERO_ADMIN
BOT_MODO_TESTE=true
BOT_LID_ADMIN=164003426902019

# Máquina de estados padrão (sem banco de dados)
# true  → usa o fluxo Braslar hardcoded (jasper_example.js) em memória — ideal para testes
# false → usa os fluxos configurados no banco de dados (padrão de produção)
BOT_STATE_MACHINE_PADRAO=true

#META
# VERIFY_TOKEN: token de verificação do webhook (configurado no painel da Meta)
