generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Usuários (autenticação admin) ──────────────────────────────────────────

model BotUsuario {
  id           String   @id @default(uuid())
  email        String   @unique @db.VarChar(255)
  senhaHash    String   @map("senha_hash") @db.VarChar(255)
  nome         String?  @db.VarChar(100)
  papel        String   @default("admin") @db.VarChar(20)
  ativo        Boolean  @default(true)
  criadoEm     DateTime @default(now()) @map("criado_em") @db.Timestamptz()
  atualizadoEm DateTime @default(now()) @updatedAt @map("atualizado_em") @db.Timestamptz()

  orgsComoMembro    OrgMembro[]
  subOrgsComoMembro SubOrgMembro[]

  @@map("bot_usuario")
}

// ── Fluxos (definições do editor visual) ───────────────────────────────────

model BotFluxo {
  id               String   @id @default(uuid())
  nome             String   @db.VarChar(100)
  descricao        String?  @db.Text
  versao           Int      @default(1)
  ativo            Boolean  @default(false)
  flowJson         Json?    @map("flow_json")
  subOrganizacaoId String?  @map("sub_organizacao_id")
  criadoEm         DateTime @default(now()) @map("criado_em") @db.Timestamptz()
  atualizadoEm     DateTime @default(now()) @updatedAt @map("atualizado_em") @db.Timestamptz()

  subOrganizacao SubOrganizacao?  @relation(fields: [subOrganizacaoId], references: [id])
  estados        BotEstadoConfig[]
  variaveis      BotFluxoVariavel[]
  yjsUpdates     YjsUpdate[]

  @@map("bot_fluxo")
}

// ── Variáveis globais do fluxo ─────────────────────────────────────────────

model BotFluxoVariavel {
  id          String  @id @default(uuid())
  flowId      String  @map("flow_id")
  chave       String  @db.VarChar(100)
  valorPadrao String? @map("valor_padrao") @db.Text

  fluxo BotFluxo @relation(fields: [flowId], references: [id], onDelete: Cascade)

  @@unique([flowId, chave])
  @@map("bot_fluxo_variaveis")
}

// ── Configuração de estados (máquina de estados) ───────────────────────────

model BotEstadoConfig {
  estado    String   @id @db.VarChar(100)
  handler   String   @db.VarChar(100)
  descricao String?  @db.Text
  ativo     Boolean  @default(true)
  config    Json     @default("{}")
  nodeId    String?  @map("node_id") @db.VarChar(50)
  nodeType  String?  @map("node_type") @db.VarChar(20)
  position  Json?    @default("{\"x\": 0, \"y\": 0}")
  flowId    String?  @map("flow_id")
  criadoEm  DateTime @default(now()) @map("criado_em") @db.Timestamptz()

  fluxo                  BotFluxo?            @relation(fields: [flowId], references: [id], onDelete: Cascade)
  transicoesOrigem         BotEstadoTransicao[] @relation("TransicaoOrigem")
  transicoesDestino        BotEstadoTransicao[] @relation("TransicaoDestino")
  usuarios                 BotEstadoUsuario[]
  keywordsGlobaisDestino   BotKeywordGlobal[]

  @@map("bot_estado_config")
}

// ── Transições entre estados ───────────────────────────────────────────────

model BotEstadoTransicao {
  id            String   @id @default(uuid())
  estadoOrigem  String   @map("estado_origem") @db.VarChar(100)
  entrada       String   @default("*") @db.VarChar(100)
  estadoDestino String   @map("estado_destino") @db.VarChar(100)
  ativo         Boolean  @default(true)
  criadoEm      DateTime @default(now()) @map("criado_em") @db.Timestamptz()

  origem  BotEstadoConfig @relation("TransicaoOrigem", fields: [estadoOrigem], references: [estado], onDelete: Cascade)
  destino BotEstadoConfig @relation("TransicaoDestino", fields: [estadoDestino], references: [estado], onDelete: Cascade)

  @@unique([estadoOrigem, entrada])
  @@map("bot_estado_transicao")
}

model BotKeywordGlobal {
  id            String   @id @default(uuid())
  keyword       String   @unique @db.VarChar(150)
  estadoDestino String   @map("estado_destino") @db.VarChar(100)
  ativo         Boolean  @default(true)
  criadoEm      DateTime @default(now()) @map("criado_em") @db.Timestamptz()
  atualizadoEm  DateTime @default(now()) @updatedAt @map("atualizado_em") @db.Timestamptz()

  destino BotEstadoConfig @relation(fields: [estadoDestino], references: [estado], onDelete: Restrict)

  @@index([estadoDestino])
  @@index([ativo])
  @@map("bot_keyword_global")
}

// ── Estado atual de cada usuário do bot ────────────────────────────────────

model BotEstadoUsuario {
  chatId       String   @id @map("chat_id") @db.VarChar(100)
  nome         String?  @db.VarChar(255)
  estadoAtual  String   @default("NOVO") @map("estado_atual") @db.VarChar(100)
  contexto     Json     @default("{}")
  criadoEm     DateTime @default(now()) @map("criado_em") @db.Timestamptz()
  atualizadoEm DateTime @default(now()) @updatedAt @map("atualizado_em") @db.Timestamptz()

  estado BotEstadoConfig @relation(fields: [estadoAtual], references: [estado])

  @@map("bot_estado_usuario")
}

// ── Histórico de transições ────────────────────────────────────────────────

model BotEstadoHistorico {
  id              String   @id @default(uuid())
  chatId          String   @map("chat_id") @db.VarChar(100)
  estadoAnterior  String   @map("estado_anterior") @db.VarChar(100)
  estadoNovo      String   @map("estado_novo") @db.VarChar(100)
  mensagemGatilho String?  @map("mensagem_gatilho") @db.Text
  config          Json     @default("{}")
  criadoEm        DateTime @default(now()) @map("criado_em") @db.Timestamptz()

  @@index([chatId], map: "idx_historico_chat")
  @@index([criadoEm(sort: Desc)], map: "idx_historico_criado")
  @@map("bot_estado_historico")
}

// ── Conversas (log de mensagens) ───────────────────────────────────────────

model Conversa {
  id         String   @id @default(uuid())
  nome       String?  @db.VarChar(255)
  dados      Json?
  quemEnviou String?  @map("quem_enviou") @db.VarChar(100)
  paraQuem   String?  @map("para_quem") @db.VarChar(100)
  mensagem   String?  @db.Text
  criadoEm   DateTime @default(now()) @map("criado_em") @db.Timestamptz()

  @@map("conversa")
}

// ── Yjs Updates (colaboração em tempo real) ────────────────────────────────

model YjsUpdate {
  id       String   @id @default(uuid())
  flowId   String   @map("flow_id")
  update   Bytes
  criadoEm DateTime @default(now()) @map("criado_em") @db.Timestamptz()

  fluxo BotFluxo @relation(fields: [flowId], references: [id], onDelete: Cascade)

  @@index([flowId])
  @@map("yjs_updates")
}

// ── Organizações ───────────────────────────────────────────────────────────

model Organizacao {
  id           String   @id @default(uuid())
  nome         String   @db.VarChar(150)
  slug         String   @unique @db.VarChar(100)
  ativa        Boolean  @default(true)
  criadoEm     DateTime @default(now()) @map("criado_em") @db.Timestamptz()
  atualizadoEm DateTime @default(now()) @updatedAt @map("atualizado_em") @db.Timestamptz()

  subOrganizacoes SubOrganizacao[]
  membros         OrgMembro[]
  apis            ApiRegistrada[]

  @@map("organizacao")
}

model SubOrganizacao {
  id              String   @id @default(uuid())
  organizacaoId   String   @map("organizacao_id")
  nome            String   @db.VarChar(150)
  slug            String   @db.VarChar(100)
  ativa           Boolean  @default(true)
  criadoEm        DateTime @default(now()) @map("criado_em") @db.Timestamptz()
  atualizadoEm    DateTime @default(now()) @updatedAt @map("atualizado_em") @db.Timestamptz()

  organizacao   Organizacao      @relation(fields: [organizacaoId], references: [id], onDelete: Cascade)
  membros       SubOrgMembro[]
  fluxos        BotFluxo[]
  apiTokens     ApiSubOrgToken[]

  @@unique([organizacaoId, slug])
  @@map("sub_organizacao")
}

// Membro de uma Organização (herda acesso a todas sub-orgs dela)
model OrgMembro {
  id             String   @id @default(uuid())
  organizacaoId  String   @map("organizacao_id")
  usuarioId      String   @map("usuario_id")
  papel          String   @default("membro") @db.VarChar(20)
  criadoEm       DateTime @default(now()) @map("criado_em") @db.Timestamptz()

  organizacao Organizacao @relation(fields: [organizacaoId], references: [id], onDelete: Cascade)
  usuario     BotUsuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@unique([organizacaoId, usuarioId])
  @@map("org_membro")
}

// Membro de uma Sub-organização específica
model SubOrgMembro {
  id               String   @id @default(uuid())
  subOrganizacaoId String   @map("sub_organizacao_id")
  usuarioId        String   @map("usuario_id")
  papel            String   @default("membro") @db.VarChar(20)
  criadoEm         DateTime @default(now()) @map("criado_em") @db.Timestamptz()

  subOrganizacao SubOrganizacao @relation(fields: [subOrganizacaoId], references: [id], onDelete: Cascade)
  usuario        BotUsuario     @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@unique([subOrganizacaoId, usuarioId])
  @@map("sub_org_membro")
}

// ── API Registry (APIs da organização) ────────────────────────────────────

model ApiRegistrada {
  id              String   @id @default(uuid())
  organizacaoId   String   @map("organizacao_id")
  nome            String   @db.VarChar(100)
  urlBase         String   @map("url_base") @db.VarChar(500)
  headers         Json     @default("{}")   // headers globais (sem token)
  criadoEm        DateTime @default(now()) @map("criado_em") @db.Timestamptz()
  atualizadoEm    DateTime @default(now()) @updatedAt @map("atualizado_em") @db.Timestamptz()

  organizacao  Organizacao      @relation(fields: [organizacaoId], references: [id], onDelete: Cascade)
  rotas        ApiRota[]
  subOrgTokens ApiSubOrgToken[]

  @@map("api_registrada")
}

model ApiRota {
  id           String   @id @default(uuid())
  apiId        String   @map("api_id")
  path         String   @db.VarChar(300)
  metodo       String   @default("GET") @db.VarChar(10)
  descricao    String?  @db.Text
  parametros   Json     @default("[]")
  bodyTemplate Json?    @map("body_template")
  criadoEm     DateTime @default(now()) @map("criado_em") @db.Timestamptz()

  api ApiRegistrada @relation(fields: [apiId], references: [id], onDelete: Cascade)

  @@map("api_rota")
}

// Token específico de cada sub-organização para uma API
model ApiSubOrgToken {
  id               String   @id @default(uuid())
  apiId            String   @map("api_id")
  subOrganizacaoId String   @map("sub_organizacao_id")
  token            String   @db.Text
  headers          Json     @default("{}")   // headers extras da sub-org (sobrescreve o global)
  criadoEm         DateTime @default(now()) @map("criado_em") @db.Timestamptz()
  atualizadoEm     DateTime @default(now()) @updatedAt @map("atualizado_em") @db.Timestamptz()

  api            ApiRegistrada  @relation(fields: [apiId], references: [id], onDelete: Cascade)
  subOrganizacao SubOrganizacao @relation(fields: [subOrganizacaoId], references: [id], onDelete: Cascade)

  @@unique([apiId, subOrganizacaoId])
  @@map("api_sub_org_token")
}
